<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nirva-Agni | Home</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/index.css">
    <style>
        .hero-image {
            margin-top: 120px;  
            margin-left: -200px; 
            width: 100%;  
            height: 100%; 
            position: relative; 
        }

        spline-viewer {
            width: 400%;  
            height: 400%; 
            border: none;
        }

        .loading-spinner {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: block;
        }

        .spinner-border {
            width: 3rem;
            height: 3rem;
            color: #007bff; 
        }
        #google_translate_element {
            position: absolute;
            top: 80px;
            right: 10px;
            z-index: 9999; /* Ensure it appears above other elements */
        }
        
    </style>
      <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                autoDisplay: false,
                includedLanguages: 'en,hi,ta,te,bn,gu' // Add your desired languages
            }, 'google_translate_element');
        }
    </script>
    <script src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</head>
<body>
    <!-- Navbar -->
    <%- include('navbar') %>
    <div id="google_translate_element"></div>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container-fluid">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <h1 class="display-3">Nirva-Agni</h1>
                    <p class="lead">AI-Powered Fire Extinguishing with Precision and Innovation</p>
                    <a href="/about" class="btn btn-primary btn-lg mt-3">Learn More</a>
                </div>
                
                <!-- 3D Model Section -->
                <div class="col-md-6">
                    <div class="hero-image">
                        <div id="loadingSpinner" class="loading-spinner">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>

                        <spline-viewer 
                            url="https://prod.spline.design/YDk3OHEwtxBupIE3/scene.splinecode" 
                            style="width: 400%; height: 400%; border: none;" 
                            disable-zoom="true" 
                            disable-rotation="true">
                        </spline-viewer>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.56/build/spline-viewer.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleMenu() {
            const mobileNav = document.getElementById('mobileNav');
            mobileNav.style.display = mobileNav.style.display === 'flex' ? 'none' : 'flex';
        }
    </script>
    <script>
        function hideSpinner() {
            setTimeout(() => {
                document.getElementById('loadingSpinner').style.display = 'none'; 
            }, 3000); 
        }

        window.onload = hideSpinner; 

        const viewer = document.querySelector('spline-viewer');
        viewer.addEventListener('load', hideSpinner); 
    </script>
</body>
</html>
